rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // We'll hardcode an admin email for bootstrapping
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'dj.taijer@gmail.com';
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'dj.taijer@gmail.com' || (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isSupport() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'support';
    }

    function isAdminOrSupport() {
      return isAdmin() || isSupport();
    }

    match /users/{userId} {
       function isValidUser(data) {
         return data.keys().hasAll(['email', 'name', 'role', 'createdAt'])
             && data.keys().size() <= 12
             && data.email is string
             && data.name is string
             && data.role is string && data.role in ['user', 'support', 'admin']
             && data.createdAt == request.time;
       }

       // Owner can always read their own data. We check this FIRST to avoid triggering isAdmin() helper if not needed.
       allow get: if isSignedIn() && request.auth.uid == userId;
       allow get: if isAdmin();
       
       // Allow listing users for DNI check, but ideally this should be restricted.
       // For better security, we allow list only if signed in.
       allow list: if isSignedIn();
       
       allow create: if isSignedIn() && request.auth.uid == userId 
                     && isValidUser(incoming()) 
                     && (incoming().role == 'user' || (incoming().role == 'admin' && isSuperAdmin()));
                     
       allow update: if (isSignedIn() && request.auth.uid == userId && (
                        // Role can only be changed by superadmin (for bootstrapping) or admin
                        (incoming().role == existing().role && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'lastName', 'dni', 'address', 'whatsapp', 'updatedAt', 'image'])) ||
                        isSuperAdmin()
                      ))
                     || isAdmin();
       allow delete: if isAdmin();
    }

     match /settings/{docId} {
       allow read: if true;
       allow write: if isAdmin();
     }
 
     match /raffles/{raffleId} {
         allow read: if true; 
         allow write: if isAdminOrSupport();
     }
     
     match /tickets/{ticketId} {
        allow get: if isSignedIn() && (request.auth.uid == existing().userId || isAdminOrSupport());
        allow list: if isSignedIn() && (isAdminOrSupport() || resource.data.userId == request.auth.uid);
        
        allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().status == 'pending_payment';
        allow update, delete: if isAdminOrSupport();
     }
  }
}
